# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=inventory_db

# JWT Configuration
JWT_SECRET=super_secret_jwt_key
JWT_EXPIRY=12h
JWT_REFRESH_SECRET=super_secret_refresh_key
JWT_REFRESH_EXPIRY=7d

# Application Configuration
NODE_ENV=production
APP_PORT=3000
FRONTEND_URL=http://localhost:5173
SYSTEM_NAME=Inventory
SYSTEM_ORG=Company

# Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=user@domain.com
MAIL_PASS=password
MAIL_FROM=user@domain.com

# Super Admin Seed Details
SUPER_ADMIN_EMAIL=admin@domain.com
SUPER_ADMIN_TEMP_PASS=Admin@123
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin

# App Config
RESET_PASSWORD_EXPIRY_MINUTES=60
