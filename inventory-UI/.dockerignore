.env
.env.local
.env.*.local
.env.development
.env.development.local

# Exclude node_modules — installed fresh inside the container
node_modules

# Exclude local dev/build artifacts
dist
.vite

# Exclude OS/editor files
.DS_Store
Thumbs.db
.idea
.vscode
