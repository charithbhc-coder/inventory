# Nginx Configuration for KTMG-Vault (Lightsail)
# File: /etc/nginx/sites-available/inventory

server {
    listen 80;
    server_name apps.myblockchainbpo.com; # Update with your custom domain if different

    # Redirect HTTP to HTTPS (Highly recommended)
    # return 301 https://$host$request_uri;

    # Frontend serving from /inventory
    location /inventory/ {
        alias /var/www/html/inventory/;
        index index.html;
        try_files $uri $uri/ /inventory/index.html;

        # Basic security headers
        add_header X-Frame-Options "SAMEORIGIN";
        add_header X-XSS-Protection "1; mode=block";
        add_header X-Content-Type-Options "nosniff";
    }

    # API Proxy
    location /api/v1/ {
        proxy_pass http://localhost:3000/api/v1/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # Uploads serving (avatars, invoices, etc.)
    location /uploads/ {
        proxy_pass http://localhost:3000/uploads/;
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }

    # Internal Socket.io (Real-time notifications)
    location /socket.io/ {
        proxy_pass http://localhost:3000/socket.io/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host $host;
    }
}
